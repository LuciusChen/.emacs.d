-  (and (fboundp 'imagemagick-types)
-       (not (eq imagemagick-types-inhibit t))
-       (not (and filename (file-name-extension filename)
-                 (memq (intern (upcase (file-name-extension filename)) obarray)
-                       imagemagick-types-inhibit)))))
+  (let* ((ext (and filename (file-name-extension filename)))
+         (ext-sym (and ext (intern (upcase ext) obarray))))
+    (and (fboundp 'imagemagick-types)
+         (not (eq imagemagick-types-inhibit t))
+         ;; Prefer native loaders for formats where we rely on their
+         ;; transparency/background behavior in pgtk.
+         (not (memq ext-sym '(PNG PNG8 PNG24 PNG32 SVG SVGZ)))
+         (not (memq ext-sym imagemagick-types-inhibit)))))
 
